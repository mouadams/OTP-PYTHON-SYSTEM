# .env  —  fill in SMTP_PASSWORD before running
APP_NAME=OTP System
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://root:@localhost/otp_system

# ── JWT ───────────────────────────────────────────────────────────────────
SECRET_KEY=super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── SMTP / Gmail ──────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your Gmail login password)
# Setup: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mouadtahiri1000@gmail.com
SMTP_PASSWORD=password-for-gmail-app
EMAIL_FROM_NAME=OTP System
